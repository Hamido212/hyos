<?xml version="1.0" encoding="UTF-8"?>

<!--
  org.hyos.Policy1
  HyOS policy engine interface.

  Bus:         Session Bus
  Object path: /org/hyos/Policy
  Service:     org.hyos.Policy1

  Every task request goes through hyos-routerd, which calls Evaluate
  before executing. hyos-policyd decides: allow / deny / require_confirmation.

  Policy modes in v0.1:
    local-only       No network (Ollama on localhost is allowed).
    read-only        No file writes, no mail sends, no shell execution.
    confirm-on-write (Future) Write actions require explicit user confirmation.
-->

<node name="/org/hyos/Policy">
  <interface name="org.hyos.Policy1">

    <!--
      Evaluate: Evaluate whether an action is permitted.

      Parameters:
        action - Dict describing the proposed action. Keys:
          "type"          (s) - Action type (matches task types from Router)
          "uri"           (s) - Target file URI, if applicable
          "network"       (b) - Whether the action requires network access
          "write"         (b) - Whether the action writes to the filesystem
          "privileged"    (b) - Whether the action requires elevated privilege

      Returns a dict with:
        "decision"    (s) - "allow", "deny", or "require_confirmation"
        "reason"      (s) - Human-readable explanation
        "policy_mode" (s) - Current mode at time of evaluation
    -->
    <method name="Evaluate">
      <arg name="action"   type="a{sv}"  direction="in"/>
      <arg name="decision" type="a{sv}"  direction="out"/>
    </method>

    <!--
      GetMode: Return the current policy mode.
    -->
    <method name="GetMode">
      <arg name="mode" type="s" direction="out"/>
    </method>

    <!--
      SetMode: Change the policy mode.

      In v0.1, only "local-only" (default) is effective.
      Setting any mode that would enable network or write access
      returns org.hyos.Error.NotImplemented.
    -->
    <method name="SetMode">
      <arg name="mode" type="s" direction="in"/>
    </method>

    <!--
      ExplainLastDecision: Return a human-readable explanation of the
      most recent policy decision made for this caller's D-Bus connection.
    -->
    <method name="ExplainLastDecision">
      <arg name="explanation" type="s" direction="out"/>
    </method>

    <!--
      ModeChanged: Emitted when the policy mode changes.
    -->
    <signal name="ModeChanged">
      <arg name="old_mode" type="s"/>
      <arg name="new_mode" type="s"/>
    </signal>

  </interface>
</node>
