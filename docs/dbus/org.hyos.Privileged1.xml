<?xml version="1.0" encoding="UTF-8"?>

<!--
  org.hyos.Privileged1
  HyOS privileged helper interface.

  Bus:         System Bus (NOT Session Bus)
  Object path: /org/hyos/Privileged
  Service:     org.hyos.Privileged1

  IMPORTANT: This service is a STUB in v0.1. All methods return
  org.hyos.Error.NotImplemented. The interface is defined here to
  establish the architecture and name ownership before implementation.

  Every method on this interface MUST:
    1. Be called over the System Bus.
    2. Call polkit to authorize the action before doing anything.
    3. Use action IDs in the tech.hyos.action.* namespace.
    4. Log every invocation (allowed and denied) to the journal.

  polkit action IDs used (to be defined in packaging/polkit/):
    tech.hyos.action.install-integration
    tech.hyos.action.enable-system-feature
    tech.hyos.action.write-system-config
-->

<node name="/org/hyos/Privileged">
  <interface name="org.hyos.Privileged1">

    <!--
      InstallIntegration: Install a HyOS integration package.

      Requires polkit action: tech.hyos.action.install-integration
      Authorization level: auth_admin

      STUB IN v0.1 — returns org.hyos.Error.NotImplemented.
    -->
    <method name="InstallIntegration">
      <arg name="package_name" type="s" direction="in"/>
    </method>

    <!--
      EnableSystemFeature: Enable a system-level HyOS feature.

      Requires polkit action: tech.hyos.action.enable-system-feature
      Authorization level: auth_admin

      STUB IN v0.1 — returns org.hyos.Error.NotImplemented.
    -->
    <method name="EnableSystemFeature">
      <arg name="feature" type="s" direction="in"/>
    </method>

    <!--
      WriteSystemConfig: Write a system-scoped configuration value.

      Requires polkit action: tech.hyos.action.write-system-config
      Authorization level: auth_admin_keep

      STUB IN v0.1 — returns org.hyos.Error.NotImplemented.
    -->
    <method name="WriteSystemConfig">
      <arg name="key"   type="s" direction="in"/>
      <arg name="value" type="s" direction="in"/>
    </method>

  </interface>
</node>
