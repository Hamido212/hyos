<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE policyconfig PUBLIC
    "-//freedesktop//DTD PolicyKit Policy Configuration 1.0//EN"
    "https://www.freedesktop.org/standards/PolicyKit/1/policyconfig.dtd">

<!--
  HyOS polkit action definitions.

  These actions cover privileged operations performed by
  hyos-privileged-helperd on the System Bus.

  All actions are STUB in v0.1 — they are defined here to register
  the action IDs but hyos-privileged-helperd returns NotImplemented.

  Authorization levels used:
    auth_admin        — Requires admin authentication (immediate)
    auth_admin_keep   — Requires admin authentication (5 min memory)
    no                — Never allowed (for future consideration)
-->

<policyconfig>

  <vendor>HyOS Project</vendor>
  <vendor_url>https://hyos.tech</vendor_url>
  <icon_name>tech.hyos.Inspector</icon_name>

  <action id="tech.hyos.action.install-integration">
    <description>Install a HyOS system integration package</description>
    <message>Authentication is required to install a HyOS integration.</message>
    <icon_name>package-install</icon_name>
    <defaults>
      <allow_any>no</allow_any>
      <allow_inactive>no</allow_inactive>
      <allow_active>auth_admin</allow_active>
    </defaults>
  </action>

  <action id="tech.hyos.action.enable-system-feature">
    <description>Enable a HyOS system-level feature</description>
    <message>Authentication is required to enable this HyOS system feature.</message>
    <icon_name>preferences-system</icon_name>
    <defaults>
      <allow_any>no</allow_any>
      <allow_inactive>no</allow_inactive>
      <allow_active>auth_admin</allow_active>
    </defaults>
  </action>

  <action id="tech.hyos.action.write-system-config">
    <description>Write a HyOS system configuration value</description>
    <message>Authentication is required to change HyOS system configuration.</message>
    <icon_name>preferences-system</icon_name>
    <defaults>
      <allow_any>no</allow_any>
      <allow_inactive>no</allow_inactive>
      <allow_active>auth_admin_keep</allow_active>
    </defaults>
  </action>

</policyconfig>
