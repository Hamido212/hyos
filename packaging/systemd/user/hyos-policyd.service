[Unit]
Description=HyOS Policy — policy engine
Documentation=https://hyos.tech/docs/services/policyd
After=dbus.socket

[Service]
Type=dbus
BusName=org.hyos.Policy1
ExecStart=%h/.local/bin/hyos-policyd

# --- Hardening ---
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=read-only
PrivateTmp=yes
PrivateDevices=yes
# Policy engine does not use network at all
RestrictAddressFamilies=AF_UNIX
MemoryDenyWriteExecute=yes
SystemCallFilter=@system-service
SystemCallErrorNumber=EPERM
LockPersonality=yes
RestrictNamespaces=yes
RestrictRealtime=yes
RemoveIPC=yes

# Policy config (read) + log storage (write)
ReadWritePaths=%h/.config/hyos %h/.local/share/hyos/policy

[Install]
WantedBy=default.target
